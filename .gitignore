# ---------------------------------------------------------------------------
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.lof
*.lot
*.nav
*.snm
*.vrb
*.spl
*.bcf
*.run.xml
*.xdv
# ---------------------------------------------------------------------------
# Python (analysis/, figs/, geom/)
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.ipynb_checkpoints/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Geant4 / CMake build dirs (sim/)
# ---------------------------------------------------------------------------
build/
sim/build/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile.cmake
*.o
*.so
*.a

# ---------------------------------------------------------------------------
# ROOT files and large data
# ---------------------------------------------------------------------------
*.root
*.hdf5
*.h5
*.npz
*.npy
*.parquet
# Large raw geometry / mesh artifacts
*.stl
*.gdml
# Large run outputs — keep the directory structure (README/.gitkeep tracked),
# ignore bulk per-run dumps. Re-add specific small released datasets explicitly.
data/runs/**/*.csv
data/runs/**/*.dat
data/runs/**/*.bin

# ---------------------------------------------------------------------------
# OS / editor cruft
# ---------------------------------------------------------------------------
.DS_Store
*.swp
*~
.idea/
.vscode/

# clangd / local dev artifacts
sim/compile_commands.json
sim/build/

# clangd index cache
**/.cache/

# generated STL meshes (regenerable via geom/generate.py + e0_pair.py)
geom/stl/*.stl
geom/stl/e0_pair/*.stl

# keep small geometry-stats raw caches (E1 outputs for S6)
!data/geom_stats/*.npz

# S5 100 MeV calibration ROOT outputs (regenerable via analysis/e0_break.py runner)
data/runs/solid_E100_t*.root

# S5.5 voxel fields (regenerable via geom/make_lattice_voxel.py + make_voronoi_voxel.py)
data/geom_stats/voxel/*.raw

# S5-verify 100 MeV confirmation ROOT outputs + voxel blocks (regenerable)
data/runs/lat_*_E100.root

# S6 campaign ROOT outputs + voxel fields (regenerable via sim/campaign.py + make_campaign_voxels.py)
data/runs/camp_*.root
data/geom_stats/voxel/*_camp_vox.raw
data/runs/_*.mac
data/runs/CAMPAIGN_LOG.tsv
# dry-run-stats analysis products (regenerated by the full campaign)
data/analysis/e2_results.json
figs/fig_neff_collapse_campaign.pdf
data/runs/CAMPAIGN_QC.md

# Regenerable figure previews
figs/preview/
